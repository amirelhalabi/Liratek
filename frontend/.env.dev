# Frontend Development Environment
# This file contains safe defaults for local development
# Copy to .env: npm run env:setup

# Development mode (auto-set by Vite, but good to document)
NODE_ENV=development

# Backend API URL (where the Express server runs)
VITE_API_URL=http://localhost:3000

# WebSocket URL (for real-time updates)
VITE_WS_URL=ws://localhost:3000

# App mode: 'standalone' for web browser, 'electron' for desktop
VITE_APP_MODE=standalone

# Enable debug logging in development
VITE_DEBUG=true
