{
  "name": "@liratek/frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "yarn workspace @liratek/core build && tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint . --max-warnings=9999",
    "test": "node ../node_modules/jest/bin/jest.js --config jest.config.ts",
    "test:coverage": "node ../node_modules/jest/bin/jest.js --config jest.config.ts --coverage --coverageDirectory ../coverage/frontend --coverageReporters=lcov",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --workers=2",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:local": "concurrently -k -s first -n backend,frontend \"yarn --cwd ../backend dev\" \"yarn dev --host 0.0.0.0 --port 5173\" --success first && wait-on http://localhost:3000/health http://localhost:5173 && playwright test"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  }
}
