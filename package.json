{
  "name": "liratek",
  "productName": "LiraTek",
  "description": "Point of Sale system for Lebanese phone shops with multi-currency support",
  "author": "Amir <amir@liratek.com>",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "start": "npm run dev",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && node scripts/prepare-electron-dist.cjs && node scripts/rebuild-native-deps.cjs && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "preview": "vite preview",

    "test": "node node_modules/jest/bin/jest.js",
    "test:watch": "npm run test -- --watch",
    "test:coverage": "npm run test -- --coverage",
    "test:ci": "npm run test -- --runInBand --colors",

    "lint": "eslint .",
    "lint:fix": "eslint . --fix",

    "format": "prettier --write .",
    "format:check": "prettier --check .",

    "typecheck": "tsc -b --pretty",

    "build": "npm run clean && tsc -b && vite build && tsc -p electron/tsconfig.json && node scripts/prepare-electron-dist.cjs",
    "build:all": "npm run build:mac && npm run build:win",
    "build:win": "npm run build && electron-builder install-app-deps --platform win32 --arch x64 && electron-builder --win --x64 && node scripts/organize-release.js",
    "build:mac": "npm run build && electron-builder install-app-deps --platform darwin && electron-builder --mac && node scripts/organize-release.js",

    "ci:build:win": "npm run build && electron-builder --win",
    "ci:build:mac": "npm run build && electron-builder --mac",

    "clean": "node -e \"['dist', 'dist-electron', 'coverage', 'releases', 'release'].forEach(dir => require('fs').rmSync(dir, {recursive:true, force:true}))\"",

    "reset:sales-debt": "node scripts/reset-sales-debt.js",

    "postinstall": "node scripts/rebuild-native-deps.cjs",
    "checks": "yarn typecheck && yarn lint && yarn format:check && yarn test:coverage && yarn build"
  },
  "dependencies": {
    "@types/recharts": "^2.0.1",
    "better-sqlite3": "^12.5.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.561.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/downloads/"
      }
    ],
    "asar": true,
    "asarUnpack": ["**/node_modules/better-sqlite3/**/*"],
    "npmRebuild": true,
    "electronVersion": "31.0.0",
    "appId": "com.liratek.pos",
    "productName": "LiraTek",
    "files": [
      "dist/index.html",
      "dist/assets/**",
      "dist/vite.svg",
      "dist-electron/**",
      "!dist-electron/**/*.test.js",
      "!dist-electron/**/__tests__/**",
      "node_modules/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "releases"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "artifactName": "mac${arch}/${productName}-${version}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "packageManager": "yarn@4.0.2+sha512.4e502bea682e7d8004561f916f1da2dfbe6f718024f6aa50bf8cd86f38ea3a94a7f1bf854a9ca666dd8eafcfb8d44baaa91bf5c7876e79a7aeac952c332f0e88"
}
