{
  "name": "liratek",
  "productName": "LiraTek",
  "description": "Electron",
  "author": "Amir <amir@liratek.com>",
  "private": true,
  "version": "1.18.43",
  "type": "module",
  "main": "dist-electron/main.js",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*",
    "electron-app"
  ],
  "scripts": {
    "dev": "npm run dev:electron",
    "dev:electron": "concurrently -k \"npm run dev:frontend\" \"wait-on tcp:5173 && npm run electron:start\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:web": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:docker": "docker compose up --build",
    "electron:start": "npm run rebuild:native && cd electron-app && npm run build && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 npm start",
    "electron:build": "cd electron-app && npm run build",
    "build": "yarn workspaces foreach -ptA --exclude liratek run build && npm run build:stage",
    "build:core": "cd packages/core && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:stage": "node scripts/build-stage.cjs",
    "build:backend": "cd backend && npm run build",
    "test": "yarn workspaces foreach -pA --exclude liratek run test",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:coverage": "yarn workspaces foreach -pA --exclude liratek run test:coverage",
    "test:coverage:frontend": "cd frontend && npm run test:coverage",
    "test:coverage:backend": "cd backend && npm run test:coverage",
    "lint": "yarn workspaces foreach -pA --exclude liratek run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "typecheck": "yarn workspaces foreach -ptA --exclude liratek run typecheck",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "typecheck:backend": "cd backend && npm run typecheck",
    "typecheck:electron": "cd electron-app && npx tsc --noEmit",
    "ci:build:win": "electron-builder --win --publish always",
    "ci:build:mac:arm": "electron-builder --mac --arm64",
    "ci:build:mac:intel": "electron-builder --mac --x64",
    "clean": "rimraf dist dist-electron coverage releases release frontend/dist frontend/coverage backend/dist backend/coverage electron-app/dist",
    "postinstall": "npm run rebuild:native",
    "rebuild:native": "node scripts/rebuild-native-deps.cjs",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ../electron-app && npm install",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@liratek/core": "workspace:*",
    "@types/recharts": "^2.0.1",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.6.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.561.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.0",
    "vite-plugin-svgr": "^4.5.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "amirelhalabi",
        "repo": "Liratek",
        "private": true
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": true,
    "electronVersion": "31.0.0",
    "appId": "com.liratek.pos",
    "productName": "LiraTek",
    "files": [
      "dist/index.html",
      "dist/assets/**",
      "dist/vite.svg",
      "dist-electron/**",
      "!dist-electron/**/*.test.js",
      "!dist-electron/**/__tests__/**",
      "node_modules/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "releases"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "LiraTek",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "packageManager": "yarn@4.12.0"
}
