# Electron App Environment Variables
# Copy this file to .env and update with your values
# See: README.md - Environment Variables section

# ============================================
# DEVELOPMENT
# ============================================
# Vite dev server URL (development only)
ELECTRON_RENDERER_URL=http://localhost:5173

# ============================================
# DATABASE
# ============================================
# Optional: Override database path
# If not set, auto-detected from:
#   1. DATABASE_PATH env var
#   2. db-path.txt file
#   3. Default platform location:
#      - macOS: ~/Library/Application Support/liratek/phone_shop.db
#      - Windows: %APPDATA%/liratek/phone_shop.db
#      - Linux: ~/.local/share/liratek/phone_shop.db
# DATABASE_PATH=/Users/<you>/Documents/LiraTek/liratek.db

# Optional: SQLCipher encryption key (32+ characters)
# DATABASE_KEY=your-strong-32-char-encryption-key-here

# ============================================
# LOGGING
# ============================================
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# ============================================
# DOCUMENTATION
# ============================================
# See README.md - Environment Variables section for full details
# See docs/LOGGING_GUIDE.md for logging configuration
