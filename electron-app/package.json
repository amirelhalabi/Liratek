{
  "name": "@liratek/electron-app",
  "version": "1.0.0",
  "description": "LiraTek Desktop Application",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "npm run build:main && npm run build:preload && npm run setup:dist",
    "build:main": "tsc -p tsconfig.json",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"require('fs').renameSync('dist/preload.js','dist/preload.cjs')\"",
    "setup:dist": "cp dist-package.json dist/package.json",
    "start": "electron .",
    "env:setup": "[ -f .env ] || cp .env.dev .env",
    "env:dev": "cp .env.dev .env",
    "env:prod": "cp .env.prod .env"
  },
  "dependencies": {
    "@liratek/core": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.2",
    "electron": "^31.0.0",
    "typescript": "~5.9.3"
  }
}
