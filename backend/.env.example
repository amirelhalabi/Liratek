# Backend Environment Variables
# Copy this file to .env and update with your values
# See: README.md - Environment Variables section

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development          # development | production | test

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000                     # API server port
HOST=0.0.0.0                  # Bind address (0.0.0.0 for all interfaces)

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173  # Frontend URL for CORS

# ============================================
# DATABASE
# ============================================
# Absolute path to SQLite database file
# Recommended locations:
#   macOS: ~/Documents/LiraTek/liratek.db
#   Linux: ~/Documents/LiraTek/liratek.db
#   Windows: C:/Users/<you>/Documents/LiraTek/liratek.db
DATABASE_PATH=/Users/<you>/Documents/LiraTek/liratek.db

# Optional: SQLCipher encryption key (32+ characters)
# REQUIRED in production for data encryption
# DATABASE_KEY=your-strong-32-char-encryption-key-here

# ============================================
# AUTHENTICATION
# ============================================
# JWT secret key (REQUIRED in production, 32+ characters)
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d             # Token expiration (7d, 24h, etc.)

# ============================================
# LOGGING
# ============================================
# Log level: trace | debug | info | warn | error | fatal
# Auto-adjusts by environment if not set:
#   - development: debug
#   - production: info
#   - test: warn
LOG_LEVEL=info

# Optional: Directory for log files (production only)
# LOG_DIR=/var/log/liratek

# ============================================
# DOCUMENTATION
# ============================================
# See README.md - Environment Variables section for full details
# See docs/LOGGING_GUIDE.md for logging configuration

# ============================================
# VOICE TRANSCRIPTION (Qwen-ASR)
# ============================================
# Alibaba Cloud DashScope API Key
# Get from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# Qwen-ASR Model Configuration
QWEN_ASR_MODEL=qwen3-asr-flash-realtime  # or qwen3-asr-pro-realtime
QWEN_ASR_REGION=singapore               # singapore | us-west-1 | eu-central-1
QWEN_ASR_LANGUAGE=en                    # en | zh | es | fr | pt | ru | ar | ja | ko
