                "api",
                "admin",
                "subscriptions",
                "clients",
                "Test Shop Essentials"
              ]
            },
            "description": "Get detailed information about Essentials plan client."
          },
          "response": []
        },
        {
          "name": "Force Sync Client Data",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/subscriptions/clients/Test Shop Professional/sync",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "admin",
                "subscriptions",
                "clients",
                "Test Shop Professional",
                "sync"
              ]
            },
            "description": "Manually trigger sync for a specific client from Google Sheets."
          },
          "response": []
        },
        {
          "name": "Get Sync Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/subscriptions/sync/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscriptions", "sync", "status"]
            },
            "description": "Get the current status of the subscription sync service."
          },
          "response": []
        },
        {
          "name": "Trigger Manual Sync",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/subscriptions/sync/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "subscriptions", "sync", "trigger"]
            },
            "description": "Manually trigger a full sync of all clients from Google Sheets."
          },
          "response": []
        },
        {
          "name": "Get Client Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/subscriptions/clients/NonExistent Shop",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "admin",
                "subscriptions",
                "clients",
                "NonExistent Shop"
              ]
            },
            "description": "Test with non-existent client - should return 404."
          },
          "response": []
        }
      ]
    },
