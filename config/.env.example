# Liratek POS - Environment Configuration
# Copy this file to .env.development, .env.production, or .env.test

# Environment: development | production | test
NODE_ENV=development

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Session timeout in milliseconds (default: 30 minutes)
SESSION_TIMEOUT=1800000

# Auto-updater: true | false
ENABLE_AUTO_UPDATE=true

# Database path (leave empty for default: ~/Library/Application Support/liratek/phone_shop.db)
DB_PATH=

# Vite dev server port
VITE_PORT=5173

# Sync interval in milliseconds (default: 5 minutes)
SYNC_INTERVAL=300000

# Drawer limits (USD)
DRAWER_LIMIT_GENERAL=50000
DRAWER_LIMIT_OMT=10000
